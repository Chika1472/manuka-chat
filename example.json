            "utterance": [
                {
                    "id": "SCRW2400000192.1.1.1",
                    "form": "음 저는 약간 국물 없이는 밥을 못 먹는 스타일이라서",
                    "original_form": "음~ 저는 약간 국물 없이는 밥을 못 먹는 스타일이라서",
                    "speaker_id": "SD2401726",
                    "start": 0.48339,
                    "end": 7.07174,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.2",
                    "form": "진짜 어릴 때부터 밥상에 찌개 하나가 있든",
                    "original_form": "진짜 어릴 때부터 밥상에 찌개 하나가 있든",
                    "speaker_id": "SD2401726",
                    "start": 7.90504,
                    "end": 12.03749,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.3",
                    "form": "국이 하나 있든 약간 그래야 됐던 거 같아요.",
                    "original_form": "국이 하나 있든 약간 그래야 됐덩 거 같애요.",
                    "speaker_id": "SD2401726",
                    "start": 12.03749,
                    "end": 15.43900,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.4",
                    "form": "집에서 조끔 까다롭게 생각했던 거 같기도 해요.",
                    "original_form": "집에서 조끔 까다롭게 생각했덩 거 같기도 해요.",
                    "speaker_id": "SD2401726",
                    "start": 15.44900,
                    "end": 19.15900,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.5",
                    "form": "그리고 지금은 먹었던 음식 또 먹는 거 별로 안 좋아하는 거 같아요.",
                    "original_form": "그리고 지금은 먹었던 음식 또 먹는 거 별로 안 좋아하능 거 같애요.",
                    "speaker_id": "SD2401726",
                    "start": 19.95000,
                    "end": 24.42000,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.6",
                    "form": "만약에 아침 점심때 먹고 남은 김치찌개가 있으면",
                    "original_form": "만약에 아침 점심때 먹고 남은 김치찌개가 있으면",
                    "speaker_id": "SD2401726",
                    "start": 24.87000,
                    "end": 30.16106,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.7",
                    "form": "저녁때는 굳이 김치찌개를 또 먹고 싶지는 않은 거 같아요.",
                    "original_form": "저녁때는 굳이 김치찌개를 또 먹고 싶지는 않응 거 같애요.",
                    "speaker_id": "SD2401726",
                    "start": 31.14435,
                    "end": 36.06000,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.8",
                    "form": "음 저는 음식을 조금 좋아하는 편인 거 같아요. 약간 미식을 즐기는 편인 거 같아요.",
                    "original_form": "음~ 저는 음식을 조금 좋아하는 편잉 거 같애요. 약간 미식을 즐기는 편잉 거 같애요.",
                    "speaker_id": "SD2401726",
                    "start": 37.93570,
                    "end": 44.70000,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.9",
                    "form": "그래서 배가 고플 때 뭐 편의점 음식이라든지 뭐 이런 걸로 간단하게 후딱 1끼 때우는 거보다는",
                    "original_form": "그서 배가 고플 때 뭐~ 편의점 음식이라든지 뭐~ 이런 걸로 간단하게 후딱 한 끼 때우는 거보다는",
                    "speaker_id": "SD2401726",
                    "start": 44.70900,
                    "end": 54.21116,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.10",
                    "form": "진짜 맛있는 음식을 제대로 1끼 챙겨 먹고 싶어 하는 경향이 있는 거 같아요.",
                    "original_form": "진짜 맛있는 음식을 제대로 한 끼 챙겨 먹고 싶어 하는 경향이 있능 거 같애요.",
                    "speaker_id": "SD2401726",
                    "start": 54.21116,
                    "end": 60.59000,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.11",
                    "form": "그래서 집에서 혼자 밥을 먹을 때도",
                    "original_form": "그래서 집에서 혼자 밥을 먹을 때도",
                    "speaker_id": "SD2401726",
                    "start": 61.18900,
                    "end": 63.71753,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.12",
                    "form": "어 냉장고에 있는 거 뭐라도 이것 1가지라도 더 꺼내서 제대로 차려 먹으려고 하는 거 같아요.",
                    "original_form": "어~ 냉장고에 있는 거 뭐라도 이것 한 가지라도 더 꺼내서 제대로 차려 먹을려고 하능 거 같애요.",
                    "speaker_id": "SD2401726",
                    "start": 65.42936,
                    "end": 73.06900,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.13",
                    "form": "어 배가 너무 고플 때 컵라면이나 편의점 음식을 먹으면 약간 우울해지는 경향이 있어요.",
                    "original_form": "어~ 배가 너무 고플 때 컵라면이나 편의점 음식을 먹으면 약간 우울해지는 경향이 있어요.",
                    "speaker_id": "SD2401726",
                    "start": 73.80000,
                    "end": 80.97000,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.14",
                    "form": "정녕 지금 먹을 게 이거밖에 없는 것인가 하고.",
                    "original_form": "정녕 지금 먹을 게 이거밖에 없는 것인가 하고.",
                    "speaker_id": "SD2401726",
                    "start": 81.87000,
                    "end": 85.46916,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.15",
                    "form": "음 맛있는 거 먹을 때가 제일 조끔 행복한 거 같아요.",
                    "original_form": "음~ 맛있는 거 먹을 때가 제일 조끔 행복항 거 같애요.",
                    "speaker_id": "SD2401726",
                    "start": 86.26913,
                    "end": 91.97000,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.16",
                    "form": "스트레스 해소에도 제일 좋은 거 같고요.",
                    "original_form": "스트레스 해소에도 제일 좋응 거 같구요.",
                    "speaker_id": "SD2401726",
                    "start": 92.16900,
                    "end": 94.70900,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.17",
                    "form": "어 먹는 걸 좋아해서",
                    "original_form": "어~ 먹는 걸 좋아해서",
                    "speaker_id": "SD2401726",
                    "start": 97.02900,
                    "end": 98.85984,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.18",
                    "form": "음식 하는 것도 꽤나 하는 편인 거 같아요.",
                    "original_form": "음식 하는 것도 꽤나 하는 편잉 거 같애요.",
                    "speaker_id": "SD2401726",
                    "start": 100.30978,
                    "end": 103.84963,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.19",
                    "form": "요즘에는 티브이에도 잘 나오고",
                    "original_form": "요즘에는 티비에도 잘 나오고",
                    "speaker_id": "SD2401726",
                    "start": 103.84963,
                    "end": 107.05619,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.20",
                    "form": "유튜브 네이버 이런 데 레시피가 엄청 잘 나오기 때문에",
                    "original_form": "유투브 네이버 이런 데 레시피가 엄청 잘 나오기 때문에",
                    "speaker_id": "SD2401726",
                    "start": 107.05619,
                    "end": 111.32932,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.21",
                    "form": "그런 것만 보고 따라 해도",
                    "original_form": "그런 것만 보고 따라 해도",
                    "speaker_id": "SD2401726",
                    "start": 111.32932,
                    "end": 113.90496,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.22",
                    "form": "반 이상은 하는 거 같아요.",
                    "original_form": "반 이상은 하능 거 같애요.",
                    "speaker_id": "SD2401726",
                    "start": 114.83826,
                    "end": 117.45900,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.23",
                    "form": "어 저도 그래서 유튜버를 잠시 했었었는데",
                    "original_form": "어~ 저도 그래서 유투버를 잠시 했었었는데",
                    "speaker_id": "SD2401726",
                    "start": 118.38900,
                    "end": 122.07304,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.24",
                    "form": "음식 해서 먹는 거 그런 것도 올리고",
                    "original_form": "음식 해서 먹는 거 그런 것도 올리고",
                    "speaker_id": "SD2401726",
                    "start": 122.43970,
                    "end": 126.13673,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.25",
                    "form": "맛있는 거 먹으러 가는 거 뭐 그런 것도 올렸던 적이 있었어요.",
                    "original_form": "맛있는 거 먹으러 가는 거 뭐~ 그런 것도 올렸던 적이 있었어요.",
                    "speaker_id": "SD2401726",
                    "start": 126.33673,
                    "end": 131.16900,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.26",
                    "form": "음 만들 수 있는 음식은 어 한식은 웬만한 거는 좀 다 만들 수 있는 거 같아요.",
                    "original_form": "음~ 만들 수 있는 음식은 어~ 한식은 웬만한 거는 쫌 다 만들 수 있능 거 같애요.",
                    "speaker_id": "SD2401726",
                    "start": 133.83900,
                    "end": 141.96000,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.27",
                    "form": "음 당연히 뭐 김치찌개 된장찌개 뭐 미역국 이렇게 이런 거는 만들 수 있고.",
                    "original_form": "음~ 당연히 뭐~ 김치찌개 된장찌개 뭐~ 미역국 이렇게 이렁 거는 만들 수 있고.",
                    "speaker_id": "SD2401726",
                    "start": 143.16900,
                    "end": 150.36365,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.28",
                    "form": "최근에",
                    "original_form": "최근에",
                    "speaker_id": "SD2401726",
                    "start": 151.39695,
                    "end": 152.53548,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.29",
                    "form": "수육을 했는데",
                    "original_form": "수육을 했는데",
                    "speaker_id": "SD2401726",
                    "start": 154.53354,
                    "end": 155.99286,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.30",
                    "form": "물을 넣고 하지 않는 무수분 수육이 있어요.",
                    "original_form": "물을 넣고 하지 않는 무수분 수육이 있어요.",
                    "speaker_id": "SD2401726",
                    "start": 156.84283,
                    "end": 160.97900,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.31",
                    "form": "그거는 냄비에다가 파 양파 어 약간 수분 많은 야채들을 밑에다 깔고",
                    "original_form": "그거는 냄비에다가 파 양파 어~ 약간 수분 많은 야채들을 밑에다 깔고",
                    "speaker_id": "SD2401726",
                    "start": 160.99000,
                    "end": 171.07931,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.32",
                    "form": "돼지고기를 놓고",
                    "original_form": "돼지고기를 놓고",
                    "speaker_id": "SD2401726",
                    "start": 171.27930,
                    "end": 173.33107,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.33",
                    "form": "그 위에 또 수분 많은 야채들을 넣어서",
                    "original_form": "그 위에 또 수분 많은 야채들을 넣어서",
                    "speaker_id": "SD2401726",
                    "start": 173.33107,
                    "end": 177.20200,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.34",
                    "form": "약불로",
                    "original_form": "약불로",
                    "speaker_id": "SD2401726",
                    "start": 177.51865,
                    "end": 178.85564,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.35",
                    "form": "찌는 건데",
                    "original_form": "찌는 건데",
                    "speaker_id": "SD2401726",
                    "start": 181.41422,
                    "end": 182.69009,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.36",
                    "form": "야채에 있는 수분이 나와서",
                    "original_form": "야채에 있는 수분이 나와서",
                    "speaker_id": "SD2401726",
                    "start": 183.17341,
                    "end": 185.84280,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.37",
                    "form": "돼지고기가 익혀져서 그런지",
                    "original_form": "돼지고기가 익혀져서 그런지",
                    "speaker_id": "SD2401726",
                    "start": 186.80943,
                    "end": 189.83793,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.38",
                    "form": "잡내도 하나도 안 나고",
                    "original_form": "잡내도 하나또 안 나고",
                    "speaker_id": "SD2401726",
                    "start": 190.02126,
                    "end": 192.14059,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.39",
                    "form": "엄청 부드럽게 맛있게 수육을 잘 먹을 수 있는 거 같아요.",
                    "original_form": "엄청 부드럽게 맛있게 수육을 잘 먹을 수 있능 거 같애요.",
                    "speaker_id": "SD2401726",
                    "start": 192.14059,
                    "end": 198.05900,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.40",
                    "form": "수육이랑 먹을 때는 배추랑 먹는 거 좋아하고.",
                    "original_form": "수육이랑 먹을 때는 배추랑 먹능 거 좋아하고.",
                    "speaker_id": "SD2401726",
                    "start": 199.24000,
                    "end": 204.51873,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.41",
                    "form": "최근에 말돈 소금이라는 것에 찍어 먹어 봤는데",
                    "original_form": "최근에 말돈 소금이라는 것에 찍어 먹어 봤는데",
                    "speaker_id": "SD2401726",
                    "start": 204.51873,
                    "end": 208.40992,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.42",
                    "form": "그것도 엄청 좋아했어요.",
                    "original_form": "그것도 엄청 좋아했어요.",
                    "speaker_id": "SD2401726",
                    "start": 208.40992,
                    "end": 210.42518,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.43",
                    "form": "맛있었어요.",
                    "original_form": "맛있었어요.",
                    "speaker_id": "SD2401726",
                    "start": 210.42518,
                    "end": 211.58000,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.44",
                    "form": "음 저는 그리고 비위가 약하긴 한데 먹는 거에는 비위가 세기 때문에",
                    "original_form": "음~ 저는 그리고 비위가 약하긴 한데 먹는 거에는 비위가 쎄기 때문에",
                    "speaker_id": "SD2401726",
                    "start": 212.99000,
                    "end": 219.17898,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.45",
                    "form": "젓갈이나 뭐 멸치젓 뭐 이런 거 비린 거 그런 것도 엄청 잘 먹는 거 같아요.",
                    "original_form": "젓갈이나 뭐~ 멸치젓 뭐~ 이런 거 비린 거 그런 것도 엄청 잘 먹능 거 같애요.",
                    "speaker_id": "SD2401726",
                    "start": 219.34564,
                    "end": 227.03900,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.46",
                    "form": "그래서 삼겹살에 멸 멸치젓 이런 거 찍어 먹는 거 엄청 좋아해요.",
                    "original_form": "그래서 삼겹살에 -멸- 멜젓 이런 거 찍어 먹능 거 엄청 좋아해요.",
                    "speaker_id": "SD2401726",
                    "start": 227.05000,
                    "end": 233.66900,
                    "note": ""
                },
                {
                    "id": "SCRW2400000192.1.1.47",
